{
	"name": "@dedalus-labs/hollywood",
	"version": "0.0.1-alpha.0",
	"private": false,
	"description": "Lights, cameras, Actions!",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dedalus-labs/hollywood.git"
	},
	"bugs": {
		"url": "https://github.com/dedalus-labs/hollywood/issues"
	},
	"homepage": "https://oss.dedaluslabs.ai/hollywood",
	"bin": {
		"hollywood": "dist/cli.js"
	},
	"files": [
		"dist",
		"README.md",
		"package.json"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./action-runtime": {
			"types": "./dist/action-runtime.d.ts",
			"import": "./dist/action-runtime.js"
		},
		"./environments": {
			"types": "./dist/environments.d.ts",
			"import": "./dist/environments.js"
		},
		"./expr": {
			"types": "./dist/expr.d.ts",
			"import": "./dist/expr.js"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check": "npm run build && node dist/cli.js check --source-root gha",
		"generate": "node dist/cli.js generate \"gha/**/*.ts\" --source-root gha --output .",
		"lint": "oxlint --vitest-plugin --import-plugin --deny-warnings . --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern .github",
		"package": "npm pack --dry-run",
		"prepack": "npm run build",
		"test": "vitest run --config vitest.config.ts",
		"typecheck": "tsgo --noEmit"
	},
	"publishConfig": {
		"access": "public",
		"tag": "alpha"
	},
	"dependencies": {
		"@actions/core": "3.0.1",
		"@actions/exec": "3.0.0",
		"@actions/expressions": "0.3.57",
		"@actions/workflow-parser": "0.3.55",
		"esbuild": "0.28.1",
		"yaml": "2.8.4"
	},
	"devDependencies": {
		"@commander-js/extra-typings": "14.0.0",
		"@types/node": "^24.12.0",
		"@typescript/native-preview": "7.0.0-dev.20260514.1",
		"commander": "14.0.3",
		"oxlint": "^1.70.0",
		"oxlint-tsgolint": "^0.22.1",
		"tinyglobby": "0.2.17",
		"tsdown": "0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.0"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "npm@11.13.0"
}
